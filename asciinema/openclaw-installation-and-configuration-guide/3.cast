[243.933073, "o", "‚ĒĆ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ē¨‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēź\r\n‚Ēā Item            ‚Ēā Value                                    ‚Ēā\r\n‚Ēú‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēľ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ē§\r\n‚Ēā Dashboard       ‚Ēā http://127.0.0.1:18789/                  ‚Ēā\r\n‚Ēā OS              ‚Ēā linux 6.8.12-14-pve (x64) ¬∑ node 24.14.0 ‚Ēā\r\n‚Ēā Tailscale       ‚Ēā \u001b[38;5;138moff\u001b[39m                                      ‚Ēā\r\n‚Ēā Channel         ‚Ēā stable (default)                         ‚Ēā\r\n‚Ēā Update          ‚Ēā pnpm ¬∑ npm latest 2026.3.7               ‚Ēā\r\n‚Ēā Gateway         ‚Ēā local ¬∑ ws://127.0.0.1:18789 (local\u001b[39m      ‚Ēā\r\n‚Ēā                 ‚Ēā loopback) ¬∑ \u001b[38;5;215munreachable (connect\u001b[39m         ‚Ēā\r\n‚Ēā                 ‚Ēā failed: connect ECONNRE"]
[243.933175, "o", "FUSED 127.0.0.\u001b[39m    ‚Ēā\r\n‚Ēā                 ‚Ēā 1:18789)\u001b[39m                                 ‚Ēā\r\n‚Ēā Gateway service ‚Ēā systemd not installed                    ‚Ēā\r\n‚Ēā Node service    ‚Ēā systemd not installed                    ‚Ēā\r\n‚Ēā Agents          ‚Ēā 1 ¬∑ no bootstrap files ¬∑ sessions 0 ¬∑    ‚Ēā\r\n‚Ēā                 ‚Ēā default main active unknown              ‚Ēā\r\n‚Ēā Memory          ‚Ēā 0 files ¬∑ 0 chunks ¬∑ \u001b[38;5;215mdirty\u001b[39m ¬∑ sources\u001b[39m     ‚Ēā\r\n‚Ēā                 ‚Ēā memory ¬∑ plugin memory-core ¬∑ \u001b[38;5;138mvector\u001b[39m     ‚Ēā\r\n‚Ēā                 ‚Ēā unknown\u001b[39m ¬∑ \u001b[38;5;78mfts ready\u001b[39m ¬∑ \u001b[38;5;78mcache on (0)\u001b[39m       ‚Ēā\r\n‚Ēā Probes          ‚Ēā \u001b[38;5;138mskipped (use --deep)\u001b[39m                     ‚Ēā\r\n‚Ēā Events          ‚Ēā none                                     ‚Ēā\r\n‚Ēā Heartbeat       ‚Ēā 30m (main)                               ‚Ēā\r\n‚Ēā Sessions        ‚Ēā 0 active ¬∑ default claude-opus-4-6       ‚Ēā\r\n‚Ēā                 ‚Ēā (200k ctx) ¬∑ ~/.openclaw/ag"]
[243.933196, "o", "ents/main/    ‚Ēā\r\n‚Ēā                 ‚Ēā sessions/sessions.json                   ‚Ēā\r\n‚ĒĒ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēī‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēė\r\n\r\n\u001b[1m\u001b[38;5;209mSecurity audit\u001b[39m\u001b[22m\r\n"]
[243.933504, "o", "\u001b[38;5;138mSummary: \u001b[38;5;167m2 critical\u001b[39m\u001b[38;5;138m ¬∑ \u001b[38;5;215m2 warn\u001b[39m\u001b[38;5;138m ¬∑ \u001b[38;5;138m1 info\u001b[39m\u001b[38;5;138m\u001b[39m\r\n  \u001b[38;5;167mCRITICAL\u001b[39m Gateway auth missing on loopback\r\n    gateway.bind is loopback but no gateway auth secret is configured. If the Control UI is exposed through a reverse proxy, unauthenticated access is possible.\r\n"]
[243.933594, "o", "    \u001b[38;5;138mFix: Set gateway.auth (token recommended) or keep the Control UI local-only.\u001b[39m\r\n  \u001b[38;5;167mCRITICAL\u001b[39m Browser control has no auth\r\n"]
[243.933798, "o", "    Browser control HTTP routes are enabled but no gateway.auth token/password is configured. Any local process (or SSRF to loopback) can call browser control endp‚Ä¶\r\n"]
[243.933821, "o", "    \u001b[38;5;138mFix: Set gateway.auth.token (recommended) or gateway.auth.password so browser control HTTP routes require authentication. Restarting the gateway will auto-generate gateway.auth.token when browser control is enabled.\u001b[39m\r\n  \u001b[38;5;215mWARN\u001b[39m Reverse proxy headers are not trusted\r\n    gateway.bind is loopback and gateway.trustedProxies is empty. If you expose the Control UI through a reverse proxy, configure trusted proxies so local-client c‚Ä¶\r\n    \u001b[38;5;138mFix: Set gateway.trustedProxies to your proxy IPs or keep the Control UI local-only.\u001b[39m\r\n  \u001b[38;5;215mWARN\u001b[39m State dir is readable by others\r\n    /root/.openclaw mode=755; consider restricting to 700.\r\n    \u001b[38;5;138mFix: chmod 700 /root/.openclaw\u001b[39m\r\n\u001b[38;5;138mFull report: openclaw security audit\u001b[39m\r\n"]
[243.934227, "o", "\u001b[38;5;138mDeep probe: openclaw security audit --deep\u001b[39m\r\n\r\n\u001b[1m\u001b[38;5;209mChannels\u001b[39m\u001b[22m\r\n"]
[243.934268, "o", "‚ĒĆ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ē¨‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ē¨‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ē¨‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēź\r\n‚Ēā Channel  ‚Ēā Enabled ‚Ēā State  ‚Ēā Detail                       ‚Ēā\r\n‚Ēú‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēľ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēľ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēľ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ē§\r\n‚ĒĒ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēī‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēī‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēī‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚Ēė\r\n"]
