[9.998658, "o", "\u001b[90m‚îÇ\u001b[39m\r\n\u001b[32m‚óá\u001b[39m  \u001b[0m\u001b[1m\u001b[38;5;209mSecurity\u001b[39m\u001b[22m\u001b[0m \u001b[90m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚ïÆ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m                                                         \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mSecurity warning ‚Äî please read.\u001b[22m                        \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m\u001b[22m                                                       \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mOpenClaw is a hobby project and still in beta. Expect\u001b[22m  \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2msharp edges.\u001b[22m                                           \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mBy default, OpenClaw is a personal agent: one trusted\u001b[22m  \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2moperator boundary.\u001b[22m                                     \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mThis bot can read files and run actions if tools are\u001b[22m   \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2menabled.\u001b[22m                      "]
[9.998705, "o", "                         \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mA bad prompt can trick it into doing unsafe things.\u001b[22m    \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m\u001b[22m                                                       \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mOpenClaw is not a hostile multi-tenant boundary by\u001b[22m     \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mdefault.\u001b[22m                                               \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mIf multiple users can message one tool-enabled agent,\u001b[22m  \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mthey share that delegated tool authority.\u001b[22m              \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m\u001b[22m                                                       \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mIf you‚Äôre not comfortable with security hardening and\u001b[22m  \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2maccess control, don‚Äôt run OpenClaw.\u001b[22m                    \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mAsk someone experienced to help before enabling tools\u001b[22m  \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mor exposing it to the"]
[9.998716, "o", " internet.\u001b[22m                        \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m\u001b[22m                                                       \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mRecommended baseline:\u001b[22m                                  \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m- Pairing/allowlists + mention gating.\u001b[22m                 \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m- Multi-user/shared inbox: split trust boundaries\u001b[22m      \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m  (separate gateway/credentials, ideally separate OS\u001b[22m   \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m  users/hosts).\u001b[22m                                        \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m- Sandbox + least-privilege tools.\u001b[22m                     \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m- Shared inboxes: isolate DM sessions\u001b[22m                  \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m  (`session.dmScope: per-channel-peer`) and keep tool\u001b[22m  \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m  access minimal.\u001b[22m                                      \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m- Keep secr"]
[9.998726, "o", "ets out of the agent‚Äôs reachable\u001b[22m            \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m  filesystem.\u001b[22m                                          \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m- Use the strongest available model for any bot with\u001b[22m   \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m  tools or untrusted inboxes.\u001b[22m                          \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m\u001b[22m                                                       \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mRun regularly:\u001b[22m                                         \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mopenclaw security audit --deep\u001b[22m                         \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mopenclaw security audit --fix\u001b[22m                          \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m\u001b[22m                                                       \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mMust read: https://docs.openclaw.ai/gateway/security\u001b[22m   \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m                                                         \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îú‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ"]
