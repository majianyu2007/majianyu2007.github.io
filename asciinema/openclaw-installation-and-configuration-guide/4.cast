[107.563434, "o", "\u001b[90m‚îÇ\u001b[39m\r\n\u001b[32m‚óá\u001b[39m  \u001b[0m\u001b[1m\u001b[38;5;209mHow channels work\u001b[39m\u001b[22m\u001b[0m \u001b[90m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚ïÆ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m                                                                         \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mDM security: default is pairing; unknown DMs get a\u001b[22m                     \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mpairing code.\u001b[22m                                                          \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mApprove with: openclaw pairing approve <channel>\u001b[22m                       \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m<code>\u001b[22m                                                                 \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mPublic DMs require dmPolicy=\"open\" + allowFrom=[\"*\"].\u001b[22m                  \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mMulti-user DMs: run: openclaw config set\u001b[22m                               \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ"]
