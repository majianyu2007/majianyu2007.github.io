[228.450297, "o", "\u001b[90m‚îÇ\u001b[39m\r\n\u001b[32m‚óá\u001b[39m  \u001b[0m\u001b[1m\u001b[38;5;209mToken\u001b[39m\u001b[22m\u001b[0m \u001b[90m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚ïÆ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m                                                         \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mGateway token: shared auth for the Gateway + Control\u001b[22m   \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mUI.\u001b[22m                                                    \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mStored in: ~/.openclaw/openclaw.json\u001b[22m                   \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m(gateway.auth.token) or OPENCLAW_GATEWAY_TOKEN.\u001b[22m        \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mView token: openclaw config get gateway.auth.token\u001b[22m     \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mGenerate token: openclaw doctor\u001b[22m                        \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2m--generate-gateway-token\u001b[22m                               \u001b[90m‚îÇ\u001b[39m\r\n\u001b[90m‚îÇ\u001b[39m  \u001b[2mWeb UI keeps dashboard URL toke"]
